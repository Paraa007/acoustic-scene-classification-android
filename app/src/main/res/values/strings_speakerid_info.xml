    <!-- Version-Zeile: "Version: " + versionsnummer / "| " / "Stand: " + datum -->
    <string name="speakerid_info_version_fmt">Version: %1$s</string>
    <string name="speakerid_info_separator">"| "</string>
    <string name="speakerid_info_date_fmt">Stand: %1$s</string>

    <!-- QR-Button: "QR-Code " + ("▼" wenn ausgeklappt, sonst "▶") -->
    <string name="speakerid_info_qr_collapsed">QR-Code ▶</string>
    <string name="speakerid_info_qr_expanded">QR-Code ▼</string>
