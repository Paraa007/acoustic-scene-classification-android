<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="18dp"
    android:paddingBottom="22dp">

    <!-- Back row: chevron + "Back" label, both tap targets behave as one button.
         Matches the Config Welcome style so the user has the same affordance on
         both Welcome screens. -->
    <LinearLayout
        android:id="@+id/testWelcomeBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="6dp"
        android:paddingEnd="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:contentDescription="@string/back">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_secondary"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/back"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/test_welcome_header"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Active-session banner: gone unless a recording is running. Tapping it
         re-attaches to the live screen (the session keeps running). -->
    <include
        android:id="@+id/testWelcomeActiveBanner"
        layout="@layout/view_active_session_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/testWelcomeSlotsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testWelcomeHistoryButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:text="@string/history"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:backgroundTint="@color/surface_dark"
        app:strokeColor="@color/hairline"
        app:strokeWidth="1dp"
        app:cornerRadius="17dp"
        app:icon="@drawable/ic_history"
        app:iconTint="@color/text_primary"
        app:iconGravity="textStart" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/test_welcome_footer"
        android:textAllCaps="true"
        android:textColor="@color/text_faint"
        android:textSize="9.5sp"
        android:letterSpacing="0.16"
        android:fontFamily="monospace" />
</LinearLayout>
