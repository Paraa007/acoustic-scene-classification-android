<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="18dp"
        android:paddingBottom="32dp">

        <!-- Back row: chevron + "Back" label, both tap targets behave as one
             button. Mirrors the Welcome screens so the user always has a
             visible way out. -->
        <LinearLayout
            android:id="@+id/passwordBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="6dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/back">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_secondary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/back"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Title block: accent-soft tile with accent lock icon -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_password_hero">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock_accent"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/password_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Password input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/password_label"
            android:textAllCaps="true"
            android:textColor="@color/text_faint"
            android:textSize="10sp"
            android:letterSpacing="0.13"
            android:fontFamily="monospace" />

        <LinearLayout
            android:id="@+id/passwordFieldRow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="4dp">

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="monospace"
                android:hint=""
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:letterSpacing="0.2"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_faint"
                android:textSize="17sp"
                android:textCursorDrawable="@null" />

            <ImageButton
                android:id="@+id/passwordRevealButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_eye"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/password_show" />
        </LinearLayout>

        <TextView
            android:id="@+id/passwordError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/password_wrong"
            android:textColor="@color/accent_red"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/passwordUnlockButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="@string/password_unlock"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="17dp" />

    </LinearLayout>
</ScrollView>
