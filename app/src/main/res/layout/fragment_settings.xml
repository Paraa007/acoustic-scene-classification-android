<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Header: chevron + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageButton
                android:id="@+id/settingsBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/wizard_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/settings"
                android:textSize="23sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Appearance section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_appearance"
            android:textAllCaps="true"
            android:textSize="9.5sp"
            android:textColor="@color/text_faint"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="9dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_tile"
            android:padding="15dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dark_mode"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/themeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/settings_theme_active_dark"
                    android:textSize="10sp"
                    android:textColor="@color/text_faint" />
            </LinearLayout>

            <!-- Light/Dark segmented toggle -->
            <LinearLayout
                android:id="@+id/themeSegmentedToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_segmented_track"
                android:padding="3dp">

                <LinearLayout
                    android:id="@+id/themeLightOption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:layout_marginEnd="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_light_mode"
                        android:contentDescription="@string/light_mode" />

                    <TextView
                        android:id="@+id/themeLightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="@string/settings_theme_light"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_faint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/themeDarkOption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:background="@drawable/bg_segmented_active"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_dark_mode"
                        android:contentDescription="@string/dark_mode"
                        app:tint="@color/accent_ink" />

                    <TextView
                        android:id="@+id/themeDarkLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="@string/settings_theme_dark"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_ink" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Models section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_models"
            android:textAllCaps="true"
            android:textSize="9.5sp"
            android:textColor="@color/text_faint"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="9dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_tile"
            android:padding="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/devModelsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- About section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textAllCaps="true"
            android:textSize="9.5sp"
            android:textColor="@color/text_faint"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="9dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_tile"
            android:padding="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="9dp"
                android:paddingVertical="11dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_app_name_label"
                    android:textSize="11.5sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name_full"
                    android:textSize="11.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/hairline" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="9dp"
                android:paddingVertical="11dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_classes_label"
                    android:textSize="11.5sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_classes_value"
                    android:textSize="11.5sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Scene legend section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_scene_legend"
            android:textAllCaps="true"
            android:textSize="9.5sp"
            android:textColor="@color/text_faint"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="9dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_tile"
            android:padding="13dp">

            <LinearLayout
                android:id="@+id/sceneLegendContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
