<?xml version="1.0" encoding="utf-8"?>
<!--
  1:1-Port von siqas `src/gui/screens/diarization_report/diarization_report.kv`.

  Wurzel: BoxLayout vertical, padding dp(15), spacing dp(10), bg_color.
  main_split wechselt die Orientierung bei root.width < dp(800)
  (vertical: beide Panels 50/50; horizontal: links 0.60 / rechts 0.40) -
  das uebernimmt das Fragment per LayoutChange-Listener.
  Kivy-Kollabieren (height 0 + opacity 0 + disabled, Spacing bleibt) wird
  als height=0 + INVISIBLE abgebildet (Margins bleiben wirksam).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Speakerid.Screen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.fzi.speakerid.ui.diarizationreport.DiarizationReportFragment">

    <!-- EXPERTEN-TAB-LEISTE (main.kv tab_bar_container): 48dp, volle Breite,
         oberhalb des gepolsterten Screen-Inhalts. In Kivy nur bei
         expert_lab_active sichtbar — dieser Screen ist ausschliesslich
         ueber den "Vergleich"-Tab des Experten-Labors erreichbar. -->
    <com.fzi.speakerid.ui.widgets.SpeakerIdExpertTabBar
        android:id="@+id/speakeridDiarizationTabBar"
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <!-- Screen-Inhalt = <DiarizationReportScreen>-Wurzel (padding 15dp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- ─── Header ─────────────────────────────────────────────────────── -->
        <com.fzi.speakerid.ui.widgets.SpeakerIdScreenHeader
            android:id="@+id/speakeridDiarizationHeader"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:speakeridHeaderTitle="@string/speakerid_diarization_report_title" />

        <!-- ─── Main Content Split Panel ───────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/speakeridDiarizationMainSplit"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- ─── LEFT PANEL: TIMELINES & CONTROLS (60 % Breite Desktop) ── -->
            <LinearLayout
                android:id="@+id/speakeridDiarizationLeftPanel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Moduswahl & Steuerung (Card: surface, PADDING_CARD [15,12], spacing 8) -->
                <LinearLayout
                    android:id="@+id/speakeridDiarizationModeCard"
                    style="@style/Speakerid.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="15dp"
                    android:paddingTop="12dp"
                    android:paddingRight="15dp"
                    android:paddingBottom="12dp">

                    <com.fzi.speakerid.ui.widgets.SpeakerIdSegmentedChoice
                        android:id="@+id/speakeridDiarizationModeChoice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:speakeridChoiceColumns="2"
                        app:speakeridChoiceLabel="@string/speakerid_diarization_report_mode_label" />

                    <!-- Dateiauswahl-Zeile (nur im Dateiauswahl-Modus, sonst 0dp hoch) -->
                    <LinearLayout
                        android:id="@+id/speakeridDiarizationFileRow"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="invisible">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/speakeridDiarizationChooseFileButton"
                            android:layout_width="120dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/speakerid_diarization_surface_dark_bg"
                            android:elevation="0dp"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:stateListAnimator="@null"
                            android:text="@string/speakerid_diarization_report_choose_wav"
                            android:textAllCaps="false"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationFileNameLabel"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:singleLine="true"
                            android:text="@string/speakerid_diarization_report_no_file"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Warning Banner (height 40 nur bei warning_message, sonst 0) -->
                <FrameLayout
                    android:id="@+id/speakeridDiarizationWarningBanner"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/speakerid_diarization_warning_bg"
                    android:paddingLeft="12dp"
                    android:paddingTop="4dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="4dp"
                    android:visibility="invisible">

                    <TextView
                        android:id="@+id/speakeridDiarizationWarningLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/speakerid_dejavu"
                        android:gravity="start|center_vertical"
                        android:textColor="@color/speakerid_error"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Timeline Widget (RelativeLayout mit surface_dark-Rundbox) -->
                <FrameLayout
                    android:id="@+id/speakeridDiarizationTimelineContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/speakerid_diarization_surface_dark_bg">

                    <com.fzi.speakerid.ui.diarizationreport.DiarizationTimelineView
                        android:id="@+id/speakeridDiarizationTimelineView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Processing overlay -->
                    <TextView
                        android:id="@+id/speakeridDiarizationProcessingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/speakerid_dejavu"
                        android:gravity="center"
                        android:text="@string/speakerid_diarization_report_processing"
                        android:textColor="@color/speakerid_accent"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- Action Bar (height 46, Button und Status-Label je size_hint 1) -->
                <LinearLayout
                    android:id="@+id/speakeridDiarizationActionBar"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/speakeridDiarizationRefreshButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/speakerid_diarization_primary_btn"
                        android:elevation="0dp"
                        android:fontFamily="@font/speakerid_dejavu"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:stateListAnimator="@null"
                        android:text="@string/speakerid_diarization_report_refresh"
                        android:textAllCaps="false"
                        android:textColor="@color/speakerid_diarization_refresh_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/speakeridDiarizationStatusLabel"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/speakerid_dejavu"
                        android:gravity="end|center_vertical"
                        android:text="@string/speakerid_diarization_report_status_default"
                        android:textColor="@color/speakerid_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ─── RIGHT PANEL: METRICS & STANDBILD SNAPSHOT (40 % Breite) ── -->
            <LinearLayout
                android:id="@+id/speakeridDiarizationRightPanel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Metriken-Karte (Insgesamt | Target) - nur im Dateiauswahl-Modus -->
                <LinearLayout
                    android:id="@+id/speakeridDiarizationMetricsCard"
                    style="@style/Speakerid.Card"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    android:paddingLeft="15dp"
                    android:paddingTop="12dp"
                    android:paddingRight="15dp"
                    android:paddingBottom="12dp"
                    android:visibility="invisible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:fontFamily="@font/speakerid_dejavu"
                        android:gravity="start|bottom"
                        android:text="@string/speakerid_diarization_report_metrics_title"
                        android:textColor="@color/speakerid_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Spaltenueberschriften -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_col_overall"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_col_target"
                            android:textColor="@color/speakerid_accent"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Fehlerrate (DER) - Kopfzeile, hervorgehoben -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:text="@string/speakerid_diarization_report_row_der"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationDerOverall"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationDerTarget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Missed speech -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:text="@string/speakerid_diarization_report_row_miss"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/speakeridDiarizationMissOverall"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationMissTarget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- False alarm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:text="@string/speakerid_diarization_report_row_fa"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/speakeridDiarizationFaOverall"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationFaTarget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Confusion -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:text="@string/speakerid_diarization_report_row_conf"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/speakeridDiarizationConfOverall"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationConfTarget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_metric_placeholder"
                            android:textColor="@color/speakerid_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Snapshot-Scatterplot-Karte -->
                <LinearLayout
                    android:id="@+id/speakeridDiarizationSnapshotCard"
                    style="@style/Speakerid.Card"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="15dp"
                    android:paddingTop="12dp"
                    android:paddingRight="15dp"
                    android:paddingBottom="12dp">

                    <!-- Kopfzeile (HEIGHT_SECTION_LABEL dp(20)) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/speakeridDiarizationSnapshotTitle"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="start|bottom"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/speakeridDiarizationSnapshotStatus"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:fontFamily="@font/speakerid_dejavu"
                            android:gravity="end|bottom"
                            android:text="@string/speakerid_diarization_report_snapshot_frozen"
                            android:textColor="@color/speakerid_text_secondary"
                            android:textSize="9sp"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <!-- PointMap im umrandeten Container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/speakerid_diarization_map_bg">

                        <com.fzi.speakerid.ui.diarizationreport.SnapshotPointMapView
                            android:id="@+id/speakeridDiarizationSnapshotMap"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
