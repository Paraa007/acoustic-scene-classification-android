<?xml version="1.0" encoding="utf-8"?>
<!-- Clickable card shown on the hub screens while a recording session runs in the
     background. Tapping it re-attaches to the live screen. Reuses the same
     surface + green-stroke + live-dot styling as the History "ACTIVE" badge so
     the two read as the same idea. The root id is overridden by the includer. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_active_badge"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:contentDescription="@string/active_banner_open">

    <View
        android:layout_width="9dp"
        android:layout_height="9dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/dot_accent_green"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/activeBannerPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Recording — Continuous" />

        <TextView
            android:id="@+id/activeBannerSecondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textSize="10.5sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            tools:text="bcres_10s +1 · 02:14" />
    </LinearLayout>

    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_arrow_back"
        android:rotation="180"
        app:tint="@color/accent_green"
        android:importantForAccessibility="no" />

</LinearLayout>
