<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <!-- Brand mark: 5-bar equalizer inside the rounded shell.
             Mockup slide 01 sizes the shell to 48px / 14px radius with a 28x28 icon. -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_app_mark">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_brand_mark"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_horizontal"
            android:text="@string/mode_select_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.25" />

        <!-- Test mode tile -->
        <LinearLayout
            android:id="@+id/modeTestTile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mode_tile"
            android:padding="18dp"
            android:layout_marginTop="36dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_circle"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/mode_select_test_title"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_select_test_chip"
                    android:textAllCaps="true"
                    android:textColor="@color/text_faint"
                    android:textSize="9sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/mode_select_test_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.45" />
        </LinearLayout>

        <!-- Configuration mode tile -->
        <LinearLayout
            android:id="@+id/modeConfigTile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mode_tile"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lock"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/mode_select_config_title"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_select_config_chip"
                    android:textAllCaps="true"
                    android:textColor="@color/text_faint"
                    android:textSize="9sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/mode_select_config_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.45" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="@string/app_name_full_display"
            android:textAllCaps="true"
            android:textColor="@color/text_faint"
            android:textSize="10sp"
            android:letterSpacing="0.16"
            android:fontFamily="monospace" />
    </LinearLayout>
</ScrollView>
