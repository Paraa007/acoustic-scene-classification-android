<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="18dp"
        android:paddingBottom="22dp">

        <!-- Back row: chevron + "Back" label, both tap targets behave as one button.
             popBackStack returns to Mode Select; system back is mirrored in the
             fragment so the hardware key behaves identically. -->
        <LinearLayout
            android:id="@+id/welcomeBackRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="6dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/back">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_secondary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/back"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- App identity: equalizer mark inside rounded shell.
             Mockup slide 03 sizes this to 64px / 18px radius with a 32x32 icon. -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_app_mark_large">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_brand_mark"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:id="@+id/welcomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_horizontal"
            android:text="@string/welcome_title_two_line"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2" />

        <!-- Primary CTA: Start new session -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewSession"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="34dp"
            android:text="@string/welcome_new_session"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="17dp"
            app:icon="@drawable/ic_record_dot"
            app:iconGravity="textStart"
            app:iconPadding="9dp"
            app:iconSize="19dp"
            app:iconTint="@color/accent_ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickStart"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/welcome_quick_start"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp"
            app:icon="@drawable/ic_lightning"
            app:iconGravity="textStart"
            app:iconPadding="9dp"
            app:iconSize="17dp"
            app:iconTint="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/history"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp"
            app:icon="@drawable/ic_history"
            app:iconGravity="textStart"
            app:iconPadding="9dp"
            app:iconSize="17dp"
            app:iconTint="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/settings"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="9dp"
            app:iconSize="17dp"
            app:iconTint="@color/text_primary" />

        <!-- Dashed accent: Configure test mode -->
        <LinearLayout
            android:id="@+id/btnConfigureTestMode"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_configure_test_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_marginEnd="9dp"
                android:src="@drawable/ic_plus"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_configure_test"
                android:textColor="@color/accent_green"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
