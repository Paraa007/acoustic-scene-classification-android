<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="22dp">

        <!-- Config mode chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_accent_soft"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="11dp"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_marginEnd="7dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/accent_green"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_chip_config"
                android:textAllCaps="true"
                android:textColor="@color/accent_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.14"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- App identity -->
        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_app_mark" />

        <TextView
            android:id="@+id/welcomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_horizontal"
            android:text="@string/app_name_full"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.18" />

        <!-- Primary CTA: Start new session -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewSession"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="34dp"
            android:text="@string/welcome_new_session"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="17dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickStart"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/welcome_quick_start"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/history"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/surface_dark"
            app:strokeColor="@color/hairline"
            app:strokeWidth="1dp"
            app:cornerRadius="17dp" />

        <!-- Dashed accent: Configure test mode -->
        <LinearLayout
            android:id="@+id/btnConfigureTestMode"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_configure_test_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_configure_test"
                android:textColor="@color/accent_green"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
