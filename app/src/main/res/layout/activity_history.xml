<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="0dp">

        <!-- Normal Toolbar -->
        <LinearLayout
            android:id="@+id/normalToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@color/surface_dark">

            <!-- Material 3 Back Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/back"
                app:icon="@drawable/ic_arrow_back"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <!-- Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/history_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Delete All Menu Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteAll"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_all_history"
                android:textColor="@color/status_error"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Selection Mode Toolbar (hidden by default) -->
        <LinearLayout
            android:id="@+id/selectionToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@color/surface_variant"
            android:visibility="gone">

            <!-- Close Selection Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseSelection"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:icon="@drawable/ic_close"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <!-- Selection Count -->
            <TextView
                android:id="@+id/selectionCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Select All Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectAll"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_select_all"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <!-- Export Selected Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_share"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <!-- Delete Selected Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_delete"
                app:iconSize="24dp"
                app:iconTint="@color/status_error"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/historyRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/emptyStateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_history"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
