<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Header: eyebrow + title + subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/eval_eyebrow"
                android:textAllCaps="true"
                android:textSize="9.5sp"
                android:textColor="@color/text_faint"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/eval_title_v2"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/eval_subtitle"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4" />

            <!-- Prediction tile + countdown tile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="15dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.4"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tile"
                    android:padding="13dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eval_predicted"
                        android:textAllCaps="true"
                        android:textSize="9.5sp"
                        android:textColor="@color/text_faint"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/predictedEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            tools:text="🌲" />

                        <TextView
                            android:id="@+id/predictedName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="Nature" />

                        <TextView
                            android:id="@+id/predictedPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:textColor="@color/text_primary"
                            tools:text="84%" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/bg_dist_track" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_tile"
                    android:padding="13dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eval_auto_skips"
                        android:textAllCaps="true"
                        android:textSize="8sp"
                        android:textColor="@color/text_faint"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.06"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        tools:text="4:32" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Select the actual scene -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="17dp"
                android:layout_marginBottom="9dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/eval_section_select"
                    android:textAllCaps="true"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="9dp"
                    android:background="@color/hairline" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sceneClassContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- "Other — write a note" toggle -->
            <LinearLayout
                android:id="@+id/otherOption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_tile"
                android:padding="13dp"
                android:layout_marginTop="7dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_eyebrow_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="11dp"
                    android:text="✎"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="11dp"
                    android:text="@string/eval_other_label"
                    android:textSize="12.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <View
                    android:id="@+id/otherCircle"
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:background="@drawable/bg_radio_circle_unselected" />
            </LinearLayout>

            <!-- Expanding note tile (visible when Other is active) -->
            <LinearLayout
                android:id="@+id/noteTile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_tile"
                android:padding="13dp"
                android:layout_marginTop="7dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/eval_note_label"
                    android:textAllCaps="true"
                    android:textSize="9sp"
                    android:textColor="@color/text_faint"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/noteInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:minHeight="64dp"
                    android:background="@drawable/bg_password_field"
                    android:padding="11dp"
                    android:gravity="top|start"
                    android:hint="@string/eval_note_hint"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_faint"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLength="240" />

                <TextView
                    android:id="@+id/noteCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:layout_gravity="end"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    tools:text="0 / 240" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky bottom action bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hairline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="22dp"
        android:paddingVertical="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:text="@string/evaluation_skip"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:strokeColor="@color/border_subtle"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1.3"
            android:text="@string/eval_send"
            android:textAllCaps="false"
            android:textColor="@color/accent_ink"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="14dp" />
    </LinearLayout>

</LinearLayout>
