<?xml version="1.0" encoding="utf-8"?>
<!--
  1:1-Port der <TableRow@BoxLayout> aus embeddings.kv - EIN Zeilentyp fuer
  row_type "header" | "centroid" | "point". Das Fragment schaltet Mindesthoehe
  (22dp Header / 42dp sonst), Sichtbarkeiten, Hintergrund (surface_dark /
  Selektion secondary 15% / transparent), Farbbalken und Texte um.
  .kv-Hoehe dp(42) nur als Minimum: die Vektor-Vorschau bricht auf schmalen
  Screens zweizeilig um und clippte in der fixen Box (Kivy clippt nicht).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/speakeridEmbeddingsRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="42dp">

    <!-- Kivy Line am unteren Rand (border_color, width 1; nur Nicht-Header) -->
    <View
        android:id="@+id/speakeridEmbeddingsRowBorder"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:background="@color/speakerid_border" />

    <!-- Farbbalken links: Rectangle pos (x, y) size (dp(4), height) -->
    <View
        android:id="@+id/speakeridEmbeddingsRowColorBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

    <!-- HEADER-Inhalt: section_label, 9sp bold, padding_x 12dp, text_secondary -->
    <TextView
        android:id="@+id/speakeridEmbeddingsRowHeaderLabel"
        style="@style/Speakerid.Text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="start|center_vertical"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/speakerid_text_secondary"
        android:visibility="gone" />

    <!-- POINT/CENTROID-Inhalt: padding dc.PADDING_CARD [15,12], spacing 6.
         wrap_content: die (ggf. zweizeilige) Vektor-Spalte bestimmt die
         Zeilenhoehe, alle match_parent-Spalten ziehen per LinearLayout-
         Remeasure mit; unterhalb der 42dp-Mindesthoehe vertikal zentriert. -->
    <LinearLayout
        android:id="@+id/speakeridEmbeddingsRowContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Spalte 1: Index / Badge (10%) -->
        <TextView
            android:id="@+id/speakeridEmbeddingsRowColIndex"
            style="@style/Speakerid.Text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.10"
            android:gravity="center"
            android:textSize="10sp"
            android:textColor="@color/speakerid_text_secondary" />

        <!-- Spalte 2: Cluster-ID (18%), 12sp bold, row_color -->
        <TextView
            android:id="@+id/speakeridEmbeddingsRowColCluster"
            style="@style/Speakerid.Text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.18"
            android:layout_marginStart="6dp"
            android:gravity="start|center_vertical"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Spalte 3: Zeitstempel (15%) -->
        <TextView
            android:id="@+id/speakeridEmbeddingsRowColTimestamp"
            style="@style/Speakerid.Text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.15"
            android:layout_marginStart="6dp"
            android:gravity="end|center_vertical"
            android:textSize="10sp"
            android:textColor="@color/speakerid_text_secondary" />

        <!-- Spalte 4: VAD/Redeanteil (15%) -->
        <TextView
            android:id="@+id/speakeridEmbeddingsRowColVad"
            style="@style/Speakerid.Text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.15"
            android:layout_marginStart="6dp"
            android:gravity="end|center_vertical"
            android:textSize="10sp"
            android:textColor="@color/speakerid_text_secondary" />

        <!-- Spalte 5: Vektor-Vorschau (42%); wrap_content = hoehentreibend -->
        <TextView
            android:id="@+id/speakeridEmbeddingsRowColVector"
            style="@style/Speakerid.Text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="0.42"
            android:layout_marginStart="6dp"
            android:gravity="end|center_vertical"
            android:textSize="9sp"
            android:textColor="@color/speakerid_text_secondary" />
    </LinearLayout>
</FrameLayout>
