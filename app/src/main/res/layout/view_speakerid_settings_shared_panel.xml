<?xml version="1.0" encoding="utf-8"?>
<!--
  Port von siqas `settings.kv` <SharedSettingsPanel@BoxLayout>:
  vertical, spacing dc.SPACING_SECTION (15dp), Hoehe = minimum_height.
  Wird per <include> eingebunden (Settings jetzt, Expert-Settings in Welle 2).
  Slider-Konfiguration (Label/Akzentfarbe/min/max/step/fmt) + Optionen der
  SegmentedChoice setzt das Fragment im Code.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Schwellenwert: Target-Matching (triangle_color primary) ── -->
    <com.fzi.speakerid.ui.settings.SpeakerSettingsSliderCard
        android:id="@+id/speakeridSettingsSliderTarget"
        android:layout_width="match_parent"
        android:layout_height="100dp" />

    <!-- ── Schwellenwert: Cluster-Matching (triangle_color secondary) ── -->
    <com.fzi.speakerid.ui.settings.SpeakerSettingsSliderCard
        android:id="@+id/speakeridSettingsSliderCluster"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="15dp" />

    <!-- ── Chunk-Laenge (min 0.4, max 1.5, step 0.1) ── -->
    <com.fzi.speakerid.ui.settings.SpeakerSettingsSliderCard
        android:id="@+id/speakeridSettingsSliderChunk"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="15dp" />

    <!-- ── Design-Theme ── -->
    <com.fzi.speakerid.ui.widgets.SpeakerIdSegmentedChoice
        android:id="@+id/speakeridSettingsChoiceTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:speakeridChoiceColumns="3"
        app:speakeridChoiceLabel="@string/speakerid_settings_theme_label" />

    <!-- ── Virtuelles Mikrofon ── -->
    <com.fzi.speakerid.ui.widgets.SpeakerIdLabeledToggle
        android:id="@+id/speakeridSettingsToggleVirtualMic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:speakeridToggleDescription="@string/speakerid_settings_virtual_mic_desc"
        app:speakeridToggleLabel="@string/speakerid_settings_virtual_mic_label" />

    <!-- ── Automatische Stimmentrennung (Pyannote) ── -->
    <com.fzi.speakerid.ui.widgets.SpeakerIdLabeledToggle
        android:id="@+id/speakeridSettingsTogglePyannote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:speakeridToggleDescription="@string/speakerid_settings_pyannote_desc"
        app:speakeridToggleLabel="@string/speakerid_settings_pyannote_label" />

</LinearLayout>
