<?xml version="1.0" encoding="utf-8"?>
<!--
    Pause-duration dialog for the live screen. Replaces the old inline picker
    card that sat at the bottom of the scroll content and was easy to miss.
    Same controls as before: slider 0..48 steps x 15 min (0 = manual resume),
    Cancel keeps recording, "Start pause" commits via the ViewModel.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/dialog_surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header: pause icon + title + big duration readout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_pause_bars_accent"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/pause_dialog_title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/pauseDialogDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace"
                tools:text="3 h 15 min" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/live_pause_picker_subtitle"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/pauseDialogSlider"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:valueFrom="0"
            android:valueTo="48"
            android:value="13"
            android:stepSize="1"
            app:thumbColor="@color/accent_green"
            app:trackColorActive="@color/accent_green"
            app:trackColorInactive="@color/hairline"
            app:tickColorActive="@color/accent_green"
            app:tickColorInactive="@color/text_faint"
            app:haloColor="@color/accent_soft"
            app:labelBehavior="gone" />

        <!-- Slider tick labels: 0 · 3h · 6h · 12h -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:layout_marginTop="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="0"
                android:textSize="8.5sp"
                android:textColor="@color/text_faint"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3h"
                android:textSize="8.5sp"
                android:textColor="@color/text_faint"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="6h"
                android:textSize="8.5sp"
                android:textColor="@color/text_faint"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="12h"
                android:textSize="8.5sp"
                android:textColor="@color/text_faint"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Confirm row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pauseDialogCancelButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="@string/cancel"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                app:strokeColor="@color/border_subtle"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pauseDialogConfirmButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:text="@string/live_pause_picker_confirm"
                android:textColor="@color/accent_ink"
                android:textAllCaps="false"
                app:backgroundTint="@color/accent_green"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
