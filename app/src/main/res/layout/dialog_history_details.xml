<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_root"
    android:layout_margin="10dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="640dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Header: close chevron + eyebrow + title + rename -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageButton
                    android:id="@+id/dialogCloseButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/back" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_eyebrow"
                        android:textAllCaps="true"
                        android:textSize="9.5sp"
                        android:textColor="@color/text_faint"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.14"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dialogTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        tools:text="Park walk" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRename"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:icon="@drawable/ic_edit"
                    app:iconTint="@color/text_secondary"
                    app:iconSize="18dp"
                    app:rippleColor="@color/surface_variant" />
            </LinearLayout>

            <!-- Mode badge: TEST MODE / CONFIG MODE. Mono uppercase rounded-pill
                 mirroring the Test-/Config-Welcome chips, so the user can tell
                 at a glance which entry point launched this session. Hidden
                 when the session has no recorded mode (legacy records). -->
            <TextView
                android:id="@+id/detailModeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_accent_soft"
                android:paddingHorizontal="11dp"
                android:paddingVertical="5dp"
                android:textSize="10sp"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.14"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="@string/detail_mode_test" />

            <!-- Meta grid: 2 columns x 4 rows. The outer tile is the rounded
                 white card; the inner container fills with border_subtle so
                 the 1dp gaps between cells read as hairline separators. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_tile"
                android:padding="6dp"
                android:layout_marginBottom="17dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_meta_grid_inner">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaStart" />
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaEnd" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaDuration" />
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaRecordings" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaPauses" />
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaModels" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaConfig" />
                        <include layout="@layout/_detail_meta_cell"
                            android:id="@+id/detailMetaBattery" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Section: MODEL PREDICTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="9dp">

                <TextView
                    android:id="@+id/modelDistributionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_section_predictions"
                    android:textAllCaps="true"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="9dp"
                    android:background="@color/hairline" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/distributionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Most-heard highlight tile (filled programmatically) -->
            <LinearLayout
                android:id="@+id/detailMostHeard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_tile_accent"
                android:padding="14dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/detailMostHeardIcon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_meta_pill">

                    <TextView
                        android:id="@+id/detailMostHeardEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textSize="18sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_most_heard_label"
                        android:textAllCaps="true"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/accent_green"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detailMostHeardName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Nature" />
                </LinearLayout>
            </LinearLayout>

            <!-- Legacy method/per-second/user-evaluation/pauses sections — kept for back-compat,
                 wrapped in the new tile background so they don't look out of place. -->

            <TextView
                android:id="@+id/methodComparisonHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_method_comparison"
                android:textAllCaps="true"
                android:textSize="9.5sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="9dp"
                android:visibility="gone" />

            <View
                android:id="@+id/methodComparisonDivider"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/methodComparisonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <View
                android:id="@+id/perSecondDivider"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/perSecondHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/per_second_clips_title"
                android:textAllCaps="true"
                android:textSize="9.5sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="9dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/perSecondContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <View
                android:id="@+id/userDistributionDivider"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/userEvaluationHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="9dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/user_evaluations"
                    android:textAllCaps="true"
                    android:textSize="9.5sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/evaluationCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_faint"
                    android:fontFamily="monospace"
                    android:textSize="10.5sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/userDistributionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="18dp" />

            <View
                android:id="@+id/pausesDivider"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/pausesHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:textSize="9.5sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="9dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/pausesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <!-- Buttons row: Export · Close (primary group) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="10dp"
                    android:text="@string/detail_export_csv"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_ink"
                    app:backgroundTint="@color/accent_green"
                    app:cornerRadius="13dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClose"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/detail_close"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    app:strokeColor="@color/border_subtle"
                    app:cornerRadius="13dp" />
            </LinearLayout>

            <!-- Delete session — ghost button, accent red, centered -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="11dp"
                android:text="@string/detail_delete"
                android:textAllCaps="false"
                android:textColor="@color/accent_red"
                app:icon="@drawable/ic_delete"
                app:iconSize="14dp"
                app:iconTint="@color/accent_red" />

            <!-- Hidden legacy fields so old findViewById doesn't crash -->
            <TextView android:id="@+id/startTimeText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/endTimeText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <LinearLayout android:id="@+id/dialogModelListLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/dialogRecordingsText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/dialogDurationText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/dialogPauseText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/dialogConfigText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/dialogBatteryText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/modelText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/modeText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/countText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/avgConfidenceText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
