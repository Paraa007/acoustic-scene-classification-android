<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="32dp">

    <!-- FZI Logo (oben, zentriert) -->
    <ImageView
        android:id="@+id/fziLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="@string/app_name"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/appTitle"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- App Title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name_full"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/fziLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/appSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_subtitle"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Primary Button - App starten -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/startAppButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/start_app"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="20dp"
        app:icon="@android:drawable/ic_btn_speak_now"
        app:iconGravity="start"
        app:iconPadding="12dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/accent_green"
        android:textColor="@color/text_primary"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toBottomOf="@+id/appSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary Button - Verlauf anzeigen -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/viewHistoryButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/view_history"
        android:textSize="16sp"
        android:padding="18dp"
        app:icon="@android:drawable/ic_menu_recent_history"
        app:iconGravity="start"
        app:iconPadding="12dp"
        app:cornerRadius="12dp"
        app:strokeColor="@color/text_primary"
        app:strokeWidth="1dp"
        app:backgroundTint="@android:color/transparent"
        android:textColor="@color/text_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/startAppButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
