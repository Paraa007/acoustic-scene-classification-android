<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/featureHubFragment">

    <!-- Root of the umbrella app ("FZI Audio Suite") — one tile per feature.
         Session-agnostic; system back from here exits the app. -->
    <fragment
        android:id="@+id/featureHubFragment"
        android:name="com.fzi.acousticscene.ui.entry.FeatureHubFragment"
        android:label="FeatureHub">
        <action
            android:id="@+id/action_hub_to_mode_select"
            app:destination="@id/modeSelectFragment" />
        <action
            android:id="@+id/action_hub_to_speakerid_placeholder"
            app:destination="@id/speakerIdPlaceholderFragment" />
        <action
            android:id="@+id/action_hub_to_speakerid"
            app:destination="@id/nav_speakerid" />
    </fragment>

    <!-- Placeholder from before the SIQAS port landed — kept but unplugged
         (the hub tile now opens the nested SIQAS graph below). -->
    <fragment
        android:id="@+id/speakerIdPlaceholderFragment"
        android:name="com.fzi.speakerid.SpeakerIdPlaceholderFragment"
        android:label="SpeakerIdPlaceholder" />

    <!-- SIQAS port (Welle 1) as a nested graph; entry = speakeridMenuFragment. -->
    <include app:graph="@navigation/nav_speakerid" />

    <!-- Acoustic Scene Classification entry — picks Test vs Config mode.
         Reached from the feature hub; the flow from here is unchanged. -->
    <fragment
        android:id="@+id/modeSelectFragment"
        android:name="com.fzi.acousticscene.ui.entry.ModeSelectFragment"
        android:label="ModeSelect">
        <action
            android:id="@+id/action_mode_to_password"
            app:destination="@id/passwordFragment" />
        <action
            android:id="@+id/action_mode_to_test_welcome"
            app:destination="@id/testWelcomeFragment" />
    </fragment>

    <!-- Developer-access gate for Configuration mode. -->
    <fragment
        android:id="@+id/passwordFragment"
        android:name="com.fzi.acousticscene.ui.entry.PasswordFragment"
        android:label="Password">
        <!-- Pop only the Password screen from the back stack on success, leave
             Mode Select underneath. From Welcome the user can press the Back
             chevron (or system back) to return to Mode Select. -->
        <action
            android:id="@+id/action_password_to_welcome"
            app:destination="@id/welcomeFragment"
            app:popUpTo="@id/passwordFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Test mode home — list of quickstart slots. -->
    <fragment
        android:id="@+id/testWelcomeFragment"
        android:name="com.fzi.acousticscene.ui.entry.TestWelcomeFragment"
        android:label="TestWelcome">
        <action
            android:id="@+id/action_test_welcome_to_live"
            app:destination="@id/liveRecordingFragment" />
        <action
            android:id="@+id/action_test_welcome_to_wizard"
            app:destination="@id/wizardFragment" />
    </fragment>

    <!-- Configuration mode home — 5 buttons including Configure test mode. -->
    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.fzi.acousticscene.ui.entry.WelcomeFragment"
        android:label="Welcome">
        <action
            android:id="@+id/action_welcome_to_wizard"
            app:destination="@id/wizardFragment" />
        <action
            android:id="@+id/action_welcome_to_settings"
            app:destination="@id/settingsFragment" />
        <!-- Re-attach to a session that's already running in the background. -->
        <action
            android:id="@+id/action_welcome_to_live"
            app:destination="@id/liveRecordingFragment" />
    </fragment>

    <fragment
        android:id="@+id/wizardFragment"
        android:name="com.fzi.acousticscene.ui.wizard.WizardFragment"
        android:label="Wizard">
        <action
            android:id="@+id/action_wizard_to_live"
            app:destination="@id/liveRecordingFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/liveRecordingFragment"
        android:name="com.fzi.acousticscene.ui.live.LiveRecordingFragment"
        android:label="Live">
        <!-- true when we navigated in to re-attach to an already-running session
             (banner tap / notification), false on the normal wizard → live path.
             Drives the back behaviour: re-entry pops back to the hub instead of
             being a no-op while classifying. -->
        <argument
            android:name="reentry"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_live_to_results"
            app:destination="@id/resultsSummaryFragment"
            app:popUpTo="@id/liveRecordingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resultsSummaryFragment"
        android:name="com.fzi.acousticscene.ui.history.ResultsSummaryFragment"
        android:label="Results" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.fzi.acousticscene.ui.common.SettingsFragment"
        android:label="@string/settings" />

</navigation>
