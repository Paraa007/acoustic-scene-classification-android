<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-Backup-Regeln (API < 31). Wir excluden die Vorhersage- und Konfigurations-
  Preferences, weil sie potenziell personenbezogene Umgebungs-Klassifikationen
  des Users enthalten (welche Räume / welche Szenen wann erkannt wurden). Die
  sollten nicht still über Google Auto-Backup in der Cloud landen.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="predictions_prefs.xml"/>
    <exclude domain="sharedpref" path="last_config_prefs.xml"/>
</full-backup-content>
