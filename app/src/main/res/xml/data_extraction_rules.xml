<?xml version="1.0" encoding="utf-8"?>
<!--
  Data-Extraction-Regeln (API 31+) für Cloud-Backup und Device-Transfer.
  Wir excluden die Vorhersage- und Konfigurations-Preferences, weil sie
  Aufnahme-Verläufe und Klassifikations-Ergebnisse enthalten.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="predictions_prefs.xml"/>
        <exclude domain="sharedpref" path="last_config_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="predictions_prefs.xml"/>
        <exclude domain="sharedpref" path="last_config_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
