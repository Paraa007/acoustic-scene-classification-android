<?xml version="1.0" encoding="utf-8"?>
<!--
  Port von `<SidebarNavButton@Button>` aus explorer.kv:
  RoundedRectangle (surface_color, Radius dc.RADIUS_CARD dp(8)) +
  1dp-Linie in border_color (rounded_rectangle Radius dp(8)).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/speakerid_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/speakerid_border" />
    <corners android:radius="8dp" />
</shape>
