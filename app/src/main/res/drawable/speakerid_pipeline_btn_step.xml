<?xml version="1.0" encoding="utf-8"?>
<!--
  pipeline.kv Button "1 Schritt": background_normal '' -> flaches Rechteck in
  secondary_color (#0E2356); canvas.before-RoundedRectangle (border_color)
  ist verdeckt. Pressed/Disabled: * 0.8 -> #0B1C44.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#0B1C44" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0B1C44" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_secondary" />
        </shape>
    </item>
</selector>
