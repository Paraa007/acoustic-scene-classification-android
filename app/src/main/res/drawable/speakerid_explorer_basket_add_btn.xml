<?xml version="1.0" encoding="utf-8"?>
<!--
  "+ Hinzufügen"-Button des Auswahl-Korbs aus explorer.kv
  (background_normal: '', flaches Rechteck):
  secondary_color bei FileChooser-Auswahl > 0, sonst surface_dark_color.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_surface_dark" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_secondary" />
        </shape>
    </item>
</selector>
