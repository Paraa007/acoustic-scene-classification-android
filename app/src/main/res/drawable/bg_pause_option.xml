<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill background for individual preset options inside the pause picker.
    Surface fill with hairline border so they read as a chip rail.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_green" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_dark" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/border_subtle" />
        </shape>
    </item>
</selector>
