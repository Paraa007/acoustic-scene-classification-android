<?xml version="1.0" encoding="utf-8"?>
<!--
  Hintergrund der Footer-Buttons aus `main_menu.kv` (Einstellungen / Info /
  Experten-Labor): RoundedRectangle mit dc.RADIUS_CARD = dp(8), Fuellung =
  surface_dim (#F0F1F3). Kein Pressed-Zustand: im .kv ist background_color
  [0,0,0,0], die Canvas-Farbe ist statisch.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="8dp" />
    <solid android:color="@color/speakerid_surface_dim" />
</shape>
