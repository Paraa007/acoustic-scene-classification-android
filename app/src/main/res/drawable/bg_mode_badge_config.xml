<?xml version="1.0" encoding="utf-8"?>
<!--
    Mode badge pill, Config variant. Same full-round pill as bg_chip_accent_soft
    plus the hairline accent stroke the active-session badge uses, so the badge
    reads as part of the existing chip family. Green = developer / Config mode.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/accent_soft" />
    <corners android:radius="999dp" />
    <stroke android:width="1dp" android:color="@color/accent_line" />
</shape>
