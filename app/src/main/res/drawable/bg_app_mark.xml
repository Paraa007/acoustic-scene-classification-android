<?xml version="1.0" encoding="utf-8"?>
<!--
    Brand-mark shell.
    Source: design-previews/minimal/v2/dark.html `.app-id-mark` (line 330-338):
    surface fill, hairline border, 13/14dp corner radius.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_dark" />
    <corners android:radius="14dp" />
    <stroke android:width="1dp" android:color="@color/border_subtle" />
</shape>
