<?xml version="1.0" encoding="utf-8"?>
<!--
  target_recorder.kv <RecorderCard@BoxLayout>:
  surface-Fuellung + RoundedRectangle radius dp(16) + Border-Line width dp(1)
  in border_color (Theme "FZI").
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/speakerid_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/speakerid_border" />
    <corners android:radius="16dp" />
</shape>
