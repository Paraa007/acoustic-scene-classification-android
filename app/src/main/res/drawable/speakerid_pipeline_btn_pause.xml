<?xml version="1.0" encoding="utf-8"?>
<!--
  pipeline.kv Auto-Analyse-Button, Zustand "PAUSE" (is_running):
  background_color error_color (#D91A1A), flaches Rechteck
  (background_normal ''). Pressed/Disabled: * 0.8 -> #AD1414.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#AD1414" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#AD1414" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_error" />
        </shape>
    </item>
</selector>
