<?xml version="1.0" encoding="utf-8"?>
<!--
  target_recorder.kv "← Zurück"-Button:
  Kivy-Button mit background_normal '' -> rechteckige Fuellung in
  surface_dark_color, darueber (canvas.after) eine 8dp-gerundete Border-Line
  (border_color). Pressed/Disabled: Hintergrund * 0.8 (Kivy-Atlas-Abdunkelung,
  #F0F1F3 * 0.8 = #C0C0C2).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#C0C0C2" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/speakerid_border" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#C0C0C2" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/speakerid_border" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/speakerid_surface_dark" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="@color/speakerid_border" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
