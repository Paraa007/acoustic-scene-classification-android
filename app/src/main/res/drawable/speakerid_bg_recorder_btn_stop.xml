<?xml version="1.0" encoding="utf-8"?>
<!--
  target_recorder.kv Aufnahme-Button (Zustand "Beenden & Speichern"):
  flaches Rechteck in error_color (#D91A1A). Pressed: * 0.8 -> #AD1414.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#AD1414" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_error" />
        </shape>
    </item>
</selector>
