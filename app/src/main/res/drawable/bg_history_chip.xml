<?xml version="1.0" encoding="utf-8"?>
<!--
    History card chip background (v2 minimal).

    Matches the mockup's .chip style: surface_variant fill (the surface-2
    token in the HTML mockup) with a hairline border. Subtly distinct from
    the outer tile so the chip cluster reads as a separate group inside
    each session card.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_variant" />
    <corners android:radius="7dp" />
    <stroke android:width="1dp" android:color="@color/border_subtle" />
</shape>
