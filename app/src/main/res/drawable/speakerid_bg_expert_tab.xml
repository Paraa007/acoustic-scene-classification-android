<?xml version="1.0" encoding="utf-8"?>
<!--
  Hintergrund eines TabButtons aus siqas `main.kv` (<TabButton@ToggleButton>):
   - Vertikale Trennlinie rechts: border_color, Kivy `Line` width dp(0.6)
     (= Halbbreite, gerenderte Staerke 1.2dp), 12dp vom oberen/unteren Rand.
   - Nur im Zustand "down": Indikator-Linie unten in Vibrant-Gruen
     [0, 0.75, 0.25] — pos x+20/y+2, Breite -40, Hoehe 3dp, Radius 2dp.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item
                android:width="1.2dp"
                android:top="12dp"
                android:bottom="12dp"
                android:gravity="end">
                <shape android:shape="rectangle">
                    <solid android:color="@color/speakerid_border" />
                </shape>
            </item>
            <item
                android:height="3dp"
                android:left="20dp"
                android:right="20dp"
                android:bottom="2dp"
                android:gravity="bottom">
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="@color/speakerid_vibrant_green" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:width="1.2dp"
                android:top="12dp"
                android:bottom="12dp"
                android:gravity="end">
                <shape android:shape="rectangle">
                    <solid android:color="@color/speakerid_border" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
