<?xml version="1.0" encoding="utf-8"?>
<!--
  Info-Screen ModernBackButton (main.kv): RoundedRectangle radius dp(25),
  normal_color = surface, pressed_color = surface_dark (kein Hover auf Touch).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_surface_dark" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_surface" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</selector>
