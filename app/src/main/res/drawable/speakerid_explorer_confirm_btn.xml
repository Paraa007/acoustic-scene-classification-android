<?xml version="1.0" encoding="utf-8"?>
<!--
  Bestaetigen-Button aus explorer.kv (Kivy-Button mit background_normal: ''):
  flaches Rechteck ohne Radius; aktiviert = primary_color,
  deaktiviert = surface_color.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_surface" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/speakerid_primary" />
        </shape>
    </item>
</selector>
