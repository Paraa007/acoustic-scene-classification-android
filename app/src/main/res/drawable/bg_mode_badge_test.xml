<?xml version="1.0" encoding="utf-8"?>
<!--
    Mode badge pill, Test variant. Mirrors bg_mode_badge_config but in the
    palette's info blue (status_info), so Test and Config sessions are
    distinguishable at a glance without shouting.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/info_soft" />
    <corners android:radius="999dp" />
    <stroke android:width="1dp" android:color="@color/info_line" />
</shape>
