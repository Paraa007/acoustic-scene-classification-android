<?xml version="1.0" encoding="utf-8"?>
<!--
    Method badge (STANDARD / FAST / AVERAGE) shown on model report tiles in the
    Session Results screen. Smaller corner radius than the meta pill and uses
    the variant surface tone so it sits flat against the white tile.
    Source: design-previews/minimal/v2/dark.html SCREEN 8 (.badge rule).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_variant" />
    <corners android:radius="5dp" />
    <stroke android:width="1dp" android:color="@color/border_subtle" />
</shape>
